# Required Slack credentials (never commit actual values)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-level-token

# Heroku Managed Inference
INFERENCE_URL=https://us.inference.heroku.com
INFERENCE_MODEL_ID=your-model-name
INFERENCE_KEY=your-mia-api-key

# Match broadcasting
BROADCAST_CHANNEL_ID=C-your-channel-id
BROADCAST_INTERVAL_IN_MS=60000

# Football API
FOOTBALL_API_KEY=your-api-key
FOOTBALL_API_URL=https://v3.football.api-sports.io
POLLER_PASSIVE_INTERVAL_IN_MS=900000
POLLER_ACTIVE_INTERVAL_IN_MS=15000

# Web Search
WEB_SEARCH_API_KEY=your-api-key
WEB_SEARCH_API_URL=https://api.tavily.com/search
WEB_SEARCH_TIMEOUT_IN_MS=10000
WEB_SEARCH_RATE_LIMIT=10

# Highlights
HIGHLIGHTS_API_KEY=your-data-api-key
HIGHLIGHTS_PLAYLIST_ID=PLBRLtDhTHh5o
HIGHLIGHTS_API_URL=https://www.googleapis.com/youtube/v3/playlistItems
HIGHLIGHTS_BASE_URL=https://www.youtube.com/watch?v=
HIGHLIGHTS_TIMEOUT_IN_MS=10000
HIGHLIGHTS_RUN_HOUR_IN_UTC=12
HIGHLIGHTS_COMMAND_FIXTURES_LIMIT=5

# Daily restart
DAILY_RESTART_HOUR_IN_UTC=11
